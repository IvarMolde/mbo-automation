PORT=3000
NODE_ENV=development
CORS_ALLOWED_ORIGINS=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# Google Cloud / Gemini
GCP_PROJECT_ID=
GCP_LOCATION=europe-north1
GEMINI_MODEL=gemini-2.5-flash

# Gmail
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Default recipient
RECIPIENT_EMAIL=

# Protect /api/cron
CRON_SECRET=
