PORT=3000
NODE_ENV=development
CORS_ALLOWED_ORIGINS=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# Google Cloud / Gemini
GCP_PROJECT_ID=
GCP_LOCATION=europe-north1
GEMINI_MODEL=gemini-2.5-flash
# Full service-account JSON as one line (required on Vercel; optional locally if ADC/key file is set)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Gmail
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Default recipient
RECIPIENT_EMAIL=

# Protect /api/cron (Vercel Cron sends Authorization: Bearer <CRON_SECRET> automatically when set)
CRON_SECRET=

# Admin-passord for nettsiden (min 12 tegn). Dette er det du logger inn med under Admin.
# Velg noe du husker — du trenger ikke å åpne Vercel for å lime inn nøkler senere.
ADMIN_TOKEN=

# Valgfri Turso-database for å lagre planendringer på Vercel (anbefalt i produksjon)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Årsplan (JSON) og CEFR-markdown (valgfrie absolutte stier; standard er repo-filer)
ARSPLAN_JSON_PATH=
CEFR_MARKDOWN_PATH=
PLAN_STATE_PATH=
